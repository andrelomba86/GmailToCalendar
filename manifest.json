{
  "manifest_version": 3,
  "name": "Gmail To Calendar",
  "description": "Detecta prazos em emails do Gmail e cria eventos em um calendario especifico do Google Calendar.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": ["identity", "storage"],
  "host_permissions": ["https://mail.google.com/*", "https://www.googleapis.com/*"],
  "oauth2": {
    "client_id": "716498284785-9t7p9nirm29ln0a4bfgndp33nqh8b3u2.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar"]
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["src/content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Gmail To Calendar"
  }
}
